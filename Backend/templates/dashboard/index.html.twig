{% extends 'base.html.twig' %}

{% block title %}Hello DashboardController!{% endblock %}

{% block body %}
<div class="p-10 text-center">
    <h2 class="text-4xl font-bold text-gray-700">Bienvenu Admin!</h2>
    <p class="mt-4 text-xl">choisir les menu pours controller les marques et les modeles et les commandes.</p>


    <div class="stats shadow mt-10">
        <div class="stat">
            <div class="stat-title">Total Marques</div>
            <div class="stat-value text-primary">{{totalMarques}}</div>
        </div>
        <div class="stat">
            <div class="stat-title">Total Modeles</div>
            <div class="stat-value text-primary">{{totalModeles}}</div>
        </div>
        <div class="stat">
            <div class="stat-title">Commandes vaovao</div>
            <div class="stat-value text-secondary">{{totalCommandes}}</div>
        </div>
    </div>
</div>
{% endblock %}