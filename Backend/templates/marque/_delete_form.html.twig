<form method="post" action="{{ path('app_marque_delete', {'id': marque.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ marque.id) }}">
    <button class="w-[35px] h-[35px] p-2 rounded-lg bg-[red]"><i class="fa-solid fa-trash text-white"></i></button>
</form>
