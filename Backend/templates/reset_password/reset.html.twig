{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
<div class="flex items-center justify-center bg-base-200 px-4">
    <div class="max-w-md w-full bg-base-100 p-8 rounded-2xl shadow-xl border border-base-300">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 text-primary rounded-full mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="id 12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-base-content">New Password</h1>
            <p class="text-sm text-base-content/60 mt-2">Ampidiro ny password vaovao hampiasainao.</p>
        </div>

        {{ form_start(resetForm, {'attr': {'class': 'space-y-4'}}) }}
            
            <div class="form-control w-full">
                {# Ny plainPassword dia matetika misy 'first' sy 'second' (Repeat Password) #}
                <div class="space-y-4">
                    <div class="group">
                        <label class="label">
                            <span class="label-text font-semibold">Password vaovao</span>
                        </label>
                        {{ form_widget(resetForm.plainPassword.first, {
                            'attr': {
                                'class': 'input input-bordered input-primary w-full focus:outline-offset-2',
                                'placeholder': '••••••••••••'
                            }
                        }) }}
                    </div>

                    <div class="group">
                        <label class="label">
                            <span class="label-text font-semibold">Avereno ilay password</span>
                        </label>
                        {{ form_widget(resetForm.plainPassword.second, {
                            'attr': {
                                'class': 'input input-bordered input-primary w-full focus:outline-offset-2',
                                'placeholder': '••••••••••••'
                            }
                        }) }}
                    </div>
                </div>

                {# Asehoy ny erreur raha tsy mitovy na malemy loatra ny password #}
                {% if form_errors(resetForm.plainPassword.first) %}
                    <div class="alert alert-error shadow-sm mt-4 py-2">
                        <div class="text-xs">{{ form_errors(resetForm.plainPassword.first) }}</div>
                    </div>
                {% endif %}
            </div>

            <div class="pt-4">
                <button type="submit" class="btn btn-primary w-full shadow-md hover:shadow-lg transition-all duration-300">
                    Hamarino ny fanovana
                </button>
            </div>

        {{ form_end(resetForm) }}

        <div class="mt-6 p-4 bg-info/5 rounded-lg border border-info/10">
            <p class="text-xs text-info-content/70 leading-relaxed text-center">
                <strong>Soso-kevitra:</strong> Mampiasà litera lehibe, isa, ary marika manokana mba ho mafy tsara ny fiarovana.
            </p>
        </div>

    </div>
</div>
{% endblock %}