{% extends 'base.html.twig' %}

{% block title %}Marque index{% endblock %}

{% block body %}

<section>
    <div class="mt-6 p-6 space-y-4">
        <h1>listes marques</h1>

        <table class="table">
            <thead class="bg-blue-700">
                <tr class="text-3xl text-white">
                    <th>Id</th>
                    <th>Nom</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
                {% for marque in marques %}
                <tr>
                    <td>{{ marque.id }}</td>
                    <td>{{ marque.nom }}</td>
                    <td>
                        <div class="flex gap-2 items-center">
                            <a href="{{ path('app_marque_show', {'id': marque.id}) }}"
                                class="w-[35px] h-[35px] bg-[#00b3ffd7] text-white p-2 rounded-lg"><i class="fa-solid fa-eye"></i></a>
                            <a href="{{ path('app_marque_edit', {'id': marque.id}) }}"
                                class="w-[35px] h-[35px] bg-[#ff5e00] text-white p-2 rounded-lg"><i class="fa-solid fa-pen"></i></a>
                            {{ include('marque/_delete_form.html.twig') }}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="3">no records found</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div>
            <a href="{{ path('app_marque_new') }}" class="w-[45px] h-[45px] p-2 bg-blue-500 text-white"><i
                    class="fa-solid fa-plus"></i>Create</a>
        </div>
    </div>
</section>




{% endblock %}